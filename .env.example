# Public
NUXT_PUBLIC_SITE_URL=https://staging.easy-west.example
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
NUXT_PUBLIC_GTM_ID=
NUXT_PUBLIC_CONTACT_PHONE=+380000000000
NUXT_PUBLIC_CONTACT_WHATSAPP=
NUXT_PUBLIC_CONTACT_TELEGRAM=
NUXT_PUBLIC_CONTACT_VIBER=
NUXT_PUBLIC_CONTACT_EMAIL=info@easywest.eu

# Deploy (VPS)
NUXT_DEPLOY_ENV=staging
NUXT_TRUSTED_PROXY=true

# Server (required at build + Nitro boot)
NUXT_RESEND_API_KEY=re_placeholder_key_32chars_min_____
NUXT_LEADS_FROM_EMAIL=leads@staging.easy-west.example
NUXT_LEADS_TO_EMAIL=staging-leads@easy-west.example
NUXT_PROD_LEADS_TO_EMAIL=leads@easy-west.example
NUXT_TELEGRAM_BOT_TOKEN=0000000000:placeholder_bot_token_min
NUXT_TELEGRAM_CHAT_ID=-1000000000000
NUXT_UPSTASH_REDIS_REST_URL=https://example.upstash.io
NUXT_UPSTASH_REDIS_REST_TOKEN=placeholder_upstash_token_min_16
NUXT_KV_REST_API_URL=https://example.upstash.io
NUXT_KV_REST_API_TOKEN=placeholder_kv_token_min_16____
NUXT_CONSENT_DB_URL=https://example.com/consent-db
NUXT_PHONE_HASH_SALT=change_me_phone_hash_salt_32chars__
NUXT_LEAD_IP_SALT=change_me_lead_ip_salt_32_chars_____
NUXT_TURNSTILE_SECRET=1x0000000000000000000000000000000AA
NUXT_QSTASH_TOKEN=placeholder_qstash_token_min_length
NUXT_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Nitro (optional overrides)
HOST=0.0.0.0
PORT=3000
