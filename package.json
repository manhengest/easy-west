{
  "name": "easy-west",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare && pnpm fonts:sync && pnpm assets:brand",
    "prebuild": "pnpm assets:brand && pnpm fonts:sync && pnpm validate:env",
    "fonts:sync": "node scripts/sync-fonts.mjs",
    "validate:env": "tsx scripts/validate-env.ts",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "lint": "stylelint \"assets/scss/**/*.scss\"",
    "lint:eslint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/scripts": "^0.11.10",
    "@nuxtjs/i18n": "^9.5.6",
    "@nuxtjs/sitemap": "^7.4.7",
    "@vee-validate/zod": "^4.15.0",
    "@vueuse/core": "^13.3.0",
    "@vueuse/motion": "^3.0.3",
    "embla-carousel-vue": "^8.6.0",
    "libphonenumber-js": "^1.12.9",
    "nuxt": "^3.21.6",
    "photoswipe": "^5.4.4",
    "tailwindcss": "^4.1.8",
    "vee-validate": "^4.15.0",
    "vue": "^3.5.34",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.84",
    "@nuxt/eslint": "^1.4.1",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.28.0",
    "happy-dom": "^20.11.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.89.1",
    "sharp": "^0.34.2",
    "stylelint": "^16.20.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.10"
  }
}
